                "invocation": "#!/bin/bash\nerr_file=$(mktemp)\noutput=$(kubectl get pods --all-namespaces -o custom-columns='NAME:.metadata.name,STATUS:.status.phase' 2>\"$err_file\")\nkubectl_exit=$?\nerr_content=$(cat \"$err_file\" 2>/dev/null)\nrm -f \"$err_file\"\n\nif [ $kubectl_exit -ne 0 ] || [ -z \"$output\" ]; then\n  if command -v jq &>/dev/null; then\n    jq -n --arg stderr \"$err_content\" '{count: 0, header: null, rows: [], stderr: $stderr}'\n  else\n    echo \"=== STDERR ===\"\n    echo \"$err_content\"\n    echo \"=== ROWS ===\"\n    echo \"=== COUNT ===\"\n    echo 0\n  fi\n  exit 0\nfi\n\n# Split header and data rows\nheader=$(echo \"$output\" | head -1)\n\ndata=$(echo \"$output\" | tail -n +2)\n\n\nif command -v jq &>/dev/null; then\n  if [ -n \"$data\" ]; then\n    rows=$(echo \"$data\" | jq -R . | jq -s '.')\n    count=$(echo \"$data\" | wc -l)\n  else\n    rows=\"[]\"\n    count=0\n  fi\n  jq -n \\\n    --argjson count \"$count\" \\\n    --arg header \"$header\" \\\n    --argjson rows \"$rows\" \\\n    --arg stderr \"$err_content\" \\\n    '{count: $count, header: $header, rows: $rows, stderr: (if $stderr == \"\" then null else $stderr end)}'\nelse\n  echo \"=== STDERR ===\"\n  echo \"$err_content\"\n  echo \"=== HEADER ===\"\n  echo \"$header\"\n  echo \"=== ROWS ===\"\n  echo \"$data\"\n  echo \"=== COUNT ===\"\n  if [ -n \"$data\" ]; then echo \"$data\" | wc -l; else echo 0; fi\nfi",
